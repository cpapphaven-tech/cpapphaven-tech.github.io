# YouTube Uploader Configurations

# Local Directory Paths
VIDEOS_DIR=../videos
CSV_PATH=../videos.csv
TRACKER_FILE=uploaded.json
LOG_FILE=logs/upload.log

# Google API Configurations
CLIENT_SECRETS_FILE=client_secrets.json
TOKEN_FILE=token.json

# Uploader Settings
# Chunk size for media uploads (in Megabytes). Recommendation is at least 1MB.
CHUNK_SIZE_MB=5
MAX_RETRIES=5

# Metadata Defaults
WEBSITE_URL=https://playmixgames.in
DEFAULT_HASHTAGS=#shorts #gaming #minigames #playmix
DEFAULT_PRIVACY_STATUS=private
